    {
      "name": "01 - Создание обязательств",
      "item": [
        {
          "name": "POST /obligations - Рекуррентная подписка Netflix",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Netflix\",\n  \"amount\": 9.99,\n  \"currency\": \"USD\",\n  \"category\": \"SUBSCRIPTION\",\n  \"recurrence\": \"MONTHLY\",\n  \"nextPaymentDate\": \"2026-07-10\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/obligations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "obligations"
              ]
            },
            "description": "Создаёт активную ежемесячную подписку и сохраняет её id в переменную окружения netflixId."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Статус 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Статус ACTIVE', function () { pm.expect(json.obligation.status).to.eql('ACTIVE'); });",
                  "pm.environment.set('netflixId', json.obligation.id);",
                  "pm.environment.set('netflixTitle', json.obligation.title);"
                ]
              }
            }
          ]
        },
